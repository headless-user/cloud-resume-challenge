server {
	listen 80 default_server;
	listen [::]:80 default_server;

	root /var/www/html;

	index index.html index.htm index.nginx-debian.html;

	server_name _;

	location / {
		try_files $uri $uri/ =404;
	}

    location /api/count {
        proxy_pass http://backend:8000/count;
        limit_req zone=one burst=5;
    }
}
